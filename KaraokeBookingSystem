    static class Room {
        final int id;
        final String name;
        final String capacity;
        final int pricePerPersonPerHour; // 1時間1人あたり料金に変更

        Room(int id, String name, String capacity, int pricePerPersonPerHour) {
            this.id = id;
            this.name = name;
            this.capacity = capacity;
            this.pricePerPersonPerHour = pricePerPersonPerHour;
        }
    }

    static class MenuItem {
        final int id;
        final String name;
        final int price;

        MenuItem(int id, String name, int price) {
            this.id = id;
            this.name = name;
            this.price = price;
        }
    }

    // 新規: 注文履歴保存用モデル
    static class OrderHistory {
        final int orderId;
        final String itemName;
        final int price;
        final int quantity;

        OrderHistory(int orderId, String itemName, int price, int quantity) {
            this.orderId = orderId;
            this.itemName = itemName;
            this.price = price;
            this.quantity = quantity;
        }
    }

    static class Booking {
        final int id;
        final Room room;
        final String customerName;
        final String phone;
        final String date;
        final String time;
        final int durationHours;
        final int guests;
        final int totalPrice;
        String status = "CONFIRMED";

        Booking(int id, Room room, String customerName, String phone, String date, String time,
                int durationHours, int guests, int totalPrice) {
            this.id = id;
            this.room = room;
            this.customerName = customerName;
            this.phone = phone;
            this.date = date;
            this.time = time;
            this.durationHours = durationHours;
            this.guests = guests;
            this.totalPrice = totalPrice;
        }
    }

    static class Database {
        private final List<Room> rooms = new ArrayList<>();
        private final List<Booking> bookings = new ArrayList<>();
        private final List<MenuItem> menuItems = new ArrayList<>();
        private final List<OrderHistory> orderHistories = new ArrayList<>(); // 注文履歴用
        private int bookingCounter = 1000;
        private int orderCounter = 5000;

        Database() {
            // 日本のカラオケに合わせ、1人1時間あたりの料金目安に調整
            rooms.add(new Room(1, "スモールルーム", "2〜4名", 400));
            rooms.add(new Room(2, "ミディアムルーム", "5〜8名", 500));
            rooms.add(new Room(3, "VIPパーティールーム", "9〜15名", 700));

            menuItems.add(new MenuItem(1, "生ビール", 600));
            menuItems.add(new MenuItem(2, "ハイボール", 550));
            menuItems.add(new MenuItem(3, "ウーロン茶", 350));
            menuItems.add(new MenuItem(4, "から揚げ盛り合わせ", 780));
            menuItems.add(new MenuItem(5, "ポテトフライ", 500));
            menuItems.add(new MenuItem(6, "ミックスナッツ", 400));
            menuItems.add(new MenuItem(7, "ミックスピザ", 900));
        }

        List<Room> getRooms() { return rooms; }
        List<MenuItem> getMenuItems() { return menuItems; }
        List<OrderHistory> getOrderHistories() { return orderHistories; } // 取得用

        List<Booking> getBookings() {
            List<Booking> active = new ArrayList<>();
            for (Booking b : bookings) {
                if (!b.status.equals("CANCELLED")) active.add(b);
            }
            return active;
        }

        void addBooking(Booking b) { bookings.add(b); }
        int nextBookingId() { return ++bookingCounter; }
        
        void addOrderHistory(OrderHistory oh) { orderHistories.add(oh); } // 追加用
        int nextOrderId() { return ++orderCounter; }

        void cancelBooking(int id) {
            for (Booking b : bookings) {
                if (b.id == id) { b.status = "CANCELLED"; break; }
            }
        }
    }
