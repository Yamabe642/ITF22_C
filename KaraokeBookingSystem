    private void styleTable(JTable table) {
        table.setFont(FONT_BODY);
        table.setRowHeight(28);
        table.setForeground(TEXT_DARK);
        table.setGridColor(BORDER_GRAY);
        table.setSelectionBackground(new Color(0xFC, 0xE4, 0xDB));
        table.getTableHeader().setFont(new Font("SansSerif", Font.BOLD, 12));
        table.getTableHeader().setBackground(PANEL_GRAY);
        table.getTableHeader().setForeground(TEXT_MUTED);
    }

    private void refreshTables() {
        if (bookingsTableModel == null || ordersTableModel == null) return;
        
        // 予約履歴テーブルの更新
        bookingsTableModel.setRowCount(0);
        for (Booking b : db.getBookings()) {
            bookingsTableModel.addRow(new Object[]{
                    b.id, b.room.name, b.date, b.time, b.durationHours, b.guests, formatYen(b.totalPrice)
            });
        }

        // 注文履歴テーブルの更新
        ordersTableModel.setRowCount(0);
        for (OrderHistory oh : db.getOrderHistories()) {
            ordersTableModel.addRow(new Object[]{
                    oh.orderId, oh.itemName, formatYen(oh.price), oh.quantity, formatYen(oh.price * oh.quantity)
            });
        }
    }

