            if (row >= 0) {
                int result = JOptionPane.showConfirmDialog(this, "選択した予約をキャンセルしますか？", "予約のキャンセル", JOptionPane.YES_NO_OPTION);
                if (result == JOptionPane.YES_OPTION) {
                    int id = (Integer) bookingsTableModel.getValueAt(row, 0);
