    private void updateTotal() {
        if (selectedRoom == null || totalPriceLabel == null) return;
        int hours = (Integer) durationSpinner.getValue();
        int guests = (Integer) guestsSpinner.getValue();
        // 料金計算を「人数 × 1人あたり料金 × 時間」に変更
        int total = selectedRoom.pricePerPersonPerHour * guests * hours;
        totalPriceLabel.setText(formatYen(total));
    }

    private void handleBookingSubmit() {
        if (selectedRoom == null) {
            bookingStatusLabel.setForeground(ACCENT);
            bookingStatusLabel.setText("最初にルームを選択してください。");
            return;
        }
        String name = textOrEmpty(nameField, "例: 山田 太郎");
        String phone = textOrEmpty(phoneField, "例: 09012345678");
        String date = textOrEmpty(dateField, "YYYY-MM-DD");
        String time = textOrEmpty(timeField, "HH:MM");

        boolean nameOk = true; // 名前の条件はなし
        boolean phoneOk = phone.matches("^(0\\d{1,4}-\\d{1,4}-\\d{4}|0\\d{9,10})$");
        boolean dateOk = date.matches("^\\d{4}-\\d{2}-\\d{2}$");
        boolean timeOk = time.matches("^\\d{2}:\\d{2}$");

        markValid(nameField, "例: 山田 太郎", nameOk);
        markValid(phoneField, "例: 09012345678", phoneOk);
        markValid(dateField, "YYYY-MM-DD", dateOk);
        markValid(timeField, "HH:MM", timeOk);

        if (!(nameOk && phoneOk && dateOk && timeOk)) {
            bookingStatusLabel.setForeground(ACCENT);
            bookingStatusLabel.setText("入力内容に不備があります。赤枠のフィールドを確認してください。");
            return;
        }

        int hours = (Integer) durationSpinner.getValue();
        int guests = (Integer) guestsSpinner.getValue();
        int total = selectedRoom.pricePerPersonPerHour * guests * hours;

        Booking booking = new Booking(
                db.nextBookingId(), selectedRoom, name, phone, date, time, hours, guests, total
        );
        db.addBooking(booking);
        lastBooking = booking;

        bookingStatusLabel.setText(" ");
        populateConfirmationScreen();
        goTo("CONFIRMATION");
    }

